{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "sh scripts/build.sh",
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/manifest.js": {
      "maxDuration": 30
    },
    "api/search.js": {
      "maxDuration": 60
    },
    "api/health.js": {
      "maxDuration": 30
    },
    "api/image.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/field/v1/manifest",
      "destination": "/api/manifest"
    },
    {
      "source": "/field/v1/search",
      "destination": "/api/search"
    }
  ]
}
