{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "sh scripts/build.sh",
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/field/[...path].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/field/:path*",
      "destination": "/api/field/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
