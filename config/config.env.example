# RESONANT real-estate field
REAL_ESTATE_PROVIDER=homeharvest
REAL_ESTATE_MAX_LISTINGS=10000
REAL_ESTATE_PAGE_SIZE=500

# One or more locations separated by |.
HOMEHARVEST_LOCATIONS="San Diego County, CA|San Diego, CA|Chula Vista, CA|Oceanside, CA|Escondido, CA|Carlsbad, CA|El Cajon, CA|Vista, CA|San Marcos, CA|Encinitas, CA"
HOMEHARVEST_LISTING_TYPES="for_sale,pending"
HOMEHARVEST_SEQUENTIAL=0
HOMEHARVEST_EXTRA_PROPERTY_DATA=0
RESONANT_MIN_PROPERTIES=500

# Existing ARBITER embedding service.
ARBITER_EMBED_URL=http://127.0.0.1:8000/v1/embed
ARBITER_EMBED_BATCH=128
ARBITER_EMBED_TIMEOUT=900
RESONANT_PORT=8797

# Optional licensed feeds. Not required for the default build.
SIMPLYRETS_BASE_URL=https://api.simplyrets.com/properties
SIMPLYRETS_KEY=
SIMPLYRETS_SECRET=
SIMPLYRETS_IDX=null
RESO_BASE_URL=
RESO_TOKEN=
RESO_FILTER="StandardStatus eq 'Active' or StandardStatus eq 'Pending'"
RESO_SELECT=
RESO_EXPAND=Media
